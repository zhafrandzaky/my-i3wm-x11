set $mod Mod4
set $term kitty
set $scripts ~/.config/i3/scripts

font pango:JetBrainsMono Nerd Font 10
# GAPS & LAYOUT
gaps inner 8
gaps outer 0
# GAP TOP: 40px (Polybar Height 24pt + Offset + Padding)
gaps top 40
default_border pixel 1
default_floating_border pixel 1

for_window [class="^.*"] border pixel 1

# WINDOW COLORS
include ~/.config/i3/themes/current/i3_colors
# GTK & APPS SETTINGS
exec_always --no-startup-id gsettings set org.gnome.desktop.interface gtk-theme "Arc-Dark"
exec_always --no-startup-id gsettings set org.gnome.desktop.interface icon-theme "Papirus-Dark"

# AUTOSTART
# Polkit agent lives in different paths per distro (Arch: polkit-gnome; Debian 12: policykit-1-gnome; Debian 13: mate-polkit or lxpolkit)
exec --no-startup-id sh -c 'for agent in /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1 /usr/libexec/polkit-gnome-authentication-agent-1 /usr/libexec/polkit-mate-authentication-agent-1 /usr/lib/mate-polkit/polkit-mate-authentication-agent-1 /usr/bin/lxpolkit; do [ -x "$agent" ] && exec "$agent"; done'
exec --no-startup-id xss-lock --transfer-sleep-lock -- $scripts/lock.sh
# Start dunst explicitly: D-Bus activation is unreliable under startx sessions
# (systemd user bus lacks DISPLAY), which stalls every notify-send for ~25s
exec --no-startup-id dunst
exec --no-startup-id nm-applet
exec --no-startup-id blueman-applet
exec --no-startup-id xfce4-power-manager
exec_always --no-startup-id ~/.config/i3/scripts/picom_launch.sh
exec_always --no-startup-id feh --bg-fill ~/.config/i3/themes/current/wallpaper.jpg
exec_always --no-startup-id ~/.config/polybar/launch.sh
exec_always --no-startup-id autotiling
# first_setup
exec_always --no-startup-id ~/.config/i3/scripts/first_setup.sh

## Show Shortcut Cheatsheet
bindsym $mod+F1 exec --no-startup-id ~/.config/i3/scripts/rofi_cheatsheet.sh

# Essentials
## Open Terminal (Kitty)
bindsym $mod+Return exec $term
## Open Web Browser (Firefox)
# Quoted: i3 splits bindsym command lists on ';' unless the exec payload is double-quoted
bindsym $mod+b exec --no-startup-id "sh -c 'command -v firefox >/dev/null 2>&1 && exec firefox; exec firefox-esr'"
## Open Code Editor (VS Code)
bindsym $mod+c exec code
## Open File Manager (Thunar)
bindsym $mod+e exec thunar
## Open Terminal Editor (Neovim)
bindsym $mod+Shift+v exec $term -e nvim
## Close Focused Window
bindsym $mod+q kill

# Menus (GUI)
## Open App Launcher (Rofi)
bindsym $mod+d exec $scripts/rofi_launcher.sh
## Open Dashboard (Media/Calendar)
bindsym $mod+Shift+d exec $scripts/rofi_dashboard.sh
## Open Power Menu
bindsym $mod+Shift+e exec $scripts/rofi_powermenu.sh
## Open Network Manager
bindsym $mod+Shift+n exec $scripts/rofi_network.sh
## Open Theme Switcher
bindsym $mod+t exec $scripts/theme_switcher.sh gui
## Open Wallpaper Manager
bindsym $mod+Shift+w exec ~/.config/i3/scripts/wallpaper_manager.sh

# Screenshots (Flameshot)
## Capture Screenshot (Select Area)
bindsym Print exec flameshot gui
## Capture Screenshot Alternative
bindsym $mod+Shift+s exec flameshot gui

# Lock Screen
## Lock Screen
bindsym $mod+Shift+x exec ~/.config/i3/scripts/lock.sh

# WINDOW FOCUS (VIM + ARROW)
## Focus Left (H / Left)
bindsym $mod+h focus left
## Focus Down (J / Down)
bindsym $mod+j focus down
## Focus Up (K / Up)
bindsym $mod+k focus up
## Focus Right (L / Right)
bindsym $mod+l focus right
# Arrow Keys
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# WINDOW MOVE (VIM + ARROW)
## Move Window Left
bindsym $mod+Shift+h move left
## Move Window Down
bindsym $mod+Shift+j move down
## Move Window Up
bindsym $mod+Shift+k move up
## Move Window Right
bindsym $mod+Shift+l move right
# Arrow Keys
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# WORKSPACES
## Switch to Workspace 1-9
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9

# Window -> Workspace
## Move Window to Workspace 1-9
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9

# NEW WORKSPACE
## Create New Workspace
bindsym $mod+n exec --no-startup-id i3-msg workspace "$(i3-msg -t get_workspaces | jq '[.[] | .num] | max + 1')"

# Layouts & Toggles
## Toggle Floating Mode
bindsym $mod+Shift+space floating toggle
## Toggle Focus (Floating/Tiled)
bindsym $mod+space focus mode_toggle
## Toggle Fullscreen
bindsym $mod+f fullscreen toggle
## Set Layout to Stacking
bindsym $mod+s layout stacking
## Set Layout to Tabbed
bindsym $mod+w layout tabbed
## Toggle Split Layout
bindsym $mod+v layout toggle split

# Hardware Controls
## Increase Volume
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
## Decrease Volume
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
## Toggle Mute
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
## Increase Brightness
bindsym XF86MonBrightnessUp exec brightnessctl s +5%
## Decrease Brightness
bindsym XF86MonBrightnessDown exec brightnessctl s 5%-
## Toggle Media Play/Pause
bindsym XF86AudioPlay exec playerctl play-pause

# System State
## Reload i3 Configuration
bindsym $mod+Shift+c reload
## Restart i3 in Place
bindsym $mod+Shift+r restart

# FLOATING RULES
for_window [class="Pavucontrol"] floating enable
for_window [class="Lxappearance"] floating enable
for_window [class="Blueman-manager"] floating enable
for_window [class="nm-connection-editor"] floating enable
for_window [class="Xfce4-power-manager-settings"] floating enable